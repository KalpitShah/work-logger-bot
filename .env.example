# Slack credentials
# Bot User OAuth Token (from OAuth & Permissions) — starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token (from Basic Information > App-Level Tokens) with connections:write — starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-token

# Google Sheets
# The ID portion of the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your-google-sheet-id

# Service account client_email from the downloaded JSON key
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Service account private_key from the downloaded JSON key.
# Keep the literal \n sequences — they are converted to real newlines at runtime.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcw...\n-----END RSA PRIVATE KEY-----"
