# Slack credentials
# Bot User OAuth Token (from OAuth & Permissions) — starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level Token (from Basic Information > App-Level Tokens) with connections:write — starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-token

# MySQL database (source of truth for the dashboard)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=work_logger
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=work_logger
# Set to "true" if your provider requires TLS (e.g. PlanetScale, Aiven).
MYSQL_SSL=false

# Google Sheets
# The ID portion of the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your-google-sheet-id

# Service account client_email from the downloaded JSON key
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Service account private_key from the downloaded JSON key.
# Keep the literal \n sequences — they are converted to real newlines at runtime.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcw...\n-----END RSA PRIVATE KEY-----"

# Web dashboard
# Port the dashboard listens on. Managed hosts (e.g. Hostinger) inject PORT
# automatically; locally it defaults to 3000 if unset.
PORT=3000

# Dashboard login credentials (change these!)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-password

# Secret used to sign session cookies. Use a long random string in production,
# e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=replace-with-a-long-random-string
