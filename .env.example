# --- Slack credentials (one Slack app per workspace) ---
# For each workspace in config/users.json, set tokens by convention:
#   SLACK_BOT_TOKEN_<ID>   (xoxb-…, from OAuth & Permissions)
#   SLACK_APP_TOKEN_<ID>   (xapp-…, App-Level Token with connections:write)
# where <ID> is the workspace id uppercased, non-alphanumerics -> "_".
# Example for a workspace with id "acme":
SLACK_BOT_TOKEN_ACME=xoxb-your-acme-bot-token
SLACK_APP_TOKEN_ACME=xapp-your-acme-app-token

# Legacy fallback: used only by a workspace whose id is exactly "default".
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# MySQL database (source of truth for the dashboard)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=work_logger
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=work_logger
# Set to "true" if your provider requires TLS (e.g. PlanetScale, Aiven).
MYSQL_SSL=false

# Google Sheets
# The ID portion of the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
# GOOGLE_SHEET_ID is now a fallback; prefer per-workspace "sheet_id" in users.json.
GOOGLE_SHEET_ID=your-google-sheet-id

# Service account client_email from the downloaded JSON key
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Service account private_key from the downloaded JSON key.
# Keep the literal \n sequences — they are converted to real newlines at runtime.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcw...\n-----END RSA PRIVATE KEY-----"

# Web dashboard
# Port the dashboard listens on. Managed hosts (e.g. Hostinger) inject PORT
# automatically; locally it defaults to 3000 if unset.
PORT=3000

# Dashboard logins.
# Define the users and the workspaces each may access in config/users.json
# (the "dashboard_users" array). Set each user's password here by convention:
#   DASHBOARD_PASSWORD_<USERNAME>   (username uppercased, non-alphanumerics -> "_")
# A user can only see the workspaces listed for them; use "*" in their
# workspaces array to grant access to every workspace.
DASHBOARD_PASSWORD_KALPIT=change-this-password
DASHBOARD_PASSWORD_SURAJ=change-this-password

# Secret used to sign session cookies. Use a long random string in production,
# e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=replace-with-a-long-random-string
